# QueueStorm Service Environment Variables Configuration

# [REQUIRED] Gemini API secret key for ticket content classification
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Allowed origins for CORS (comma-separated). Defaults to '*' for local dev.
# FRONTEND_ORIGIN=http://localhost:3000

# [OPTIONAL] Triage API endpoint accessed by the frontend build. Defaults to http://localhost:8000.
# VITE_API_BASE_URL=http://localhost:8000
